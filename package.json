{
  "license": "MIT",
  "main": "index.js",
  "name": "basis",
  "private": true,
  "version": "1.0.0",
  "dependencies": {
    "eslint": "^10.1.0",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.9",
    "@types/bun": "^1.3.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bun-types": "^1.3.11",
    "chalk": "^5.6.2",
    "husky": "^9.1.7",
    "svg-path-commander": "^2.1.11",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "bun run --filter='*' build",
    "docs": "bun ./libraries/docs/index.html",
    "lint": "bun run lint:es && bun run lint:ts",
    "lint:es": "bun run update:linter && bun eslint .",
    "lint:ts": "bun tsc --noEmit",
    "prepare": "husky",
    "test:develop": "bun test --watch",
    "up": "bunx npm-check-updates -p bun --enginesNode --upgrade --root --workspaces",
    "update:linter": "bun --filter=@basis/eslint-plugin run build",
    "workspace": "bun ./libraries/workspaces/source/bin/workspace.ts",
    "ws": "bun workspace"
  },
  "type": "module",
  "workspaces": [
    "libraries/*",
    "testing/*",
    "packages/*"
  ],
  "trustedDependencies": [
    "@basis/workspaces"
  ],
  "patchedDependencies": {
    "eslint-plugin-import@2.32.0": "patches/eslint-plugin-import@2.32.0.patch",
    "eslint-plugin-named-import-spacing@1.0.3": "patches/eslint-plugin-named-import-spacing@1.0.3.patch",
    "eslint-plugin-sort-keys-fix@1.1.2": "patches/eslint-plugin-sort-keys-fix@1.1.2.patch",
    "eslint-plugin-typescript-sort-keys@3.3.0": "patches/eslint-plugin-typescript-sort-keys@3.3.0.patch"
  }
}
